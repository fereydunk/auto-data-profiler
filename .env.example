# Copy to .env and fill in your values before running docker-compose or the pipeline.

# ── Confluent Cloud Kafka ─────────────────────────────────────────────────────
# From: Confluent Cloud → Cluster → API Keys
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxxx.us-east-1.aws.confluent.cloud:9092
CONFLUENT_API_KEY=your-kafka-api-key
CONFLUENT_API_SECRET=your-kafka-api-secret

# ── Schema Registry / Stream Catalog ─────────────────────────────────────────
# From: Confluent Cloud → Schema Registry → API Keys
CONFLUENT_SR_URL=https://psrc-xxxxxx.us-east-2.aws.confluent.cloud
CONFLUENT_SR_API_KEY=your-sr-api-key
CONFLUENT_SR_API_SECRET=your-sr-api-secret
# From: Confluent Cloud → Schema Registry → Cluster settings → Cluster ID
CONFLUENT_SR_CLUSTER_ID=lsrc-xxxxxx

# ── Topics ────────────────────────────────────────────────────────────────────
SOURCE_TOPIC=raw-messages
SINK_TOPIC_CLASSIFIED=classified-messages   # messages with at least one tag detected
SINK_TOPIC_SAFE=classified-safe             # messages with no tags detected
SINK_TOPIC_AUDIT=classification-audit       # lightweight audit record for every message
CONSUMER_GROUP=auto-data-classifier

# ── Services ──────────────────────────────────────────────────────────────────
CLASSIFIER_URL=http://classifier:8000       # set to ngrok URL when running natively
REVIEW_API_URL=http://review-api:8001
PROFILER_URL=http://profiler:8002           # set to http://localhost:8002 when running natively

# ── Classification depth ──────────────────────────────────────────────────────
# 1 = field name only (zero data access, instant)
# 2 = + regex / structural patterns
# 3 = + AI model: spaCy NER + GLiNER  (default — most accurate)
MAX_LAYER=3

# ── Pipeline tuning ───────────────────────────────────────────────────────────
BATCH_SIZE=50                   # messages per Kafka commit
MAX_CONCURRENT=10               # max parallel /classify calls
CLASSIFIER_TIMEOUT_S=5.0        # per-request timeout (seconds)
